{
  "schema": "story_lines_v1",
  "purpose": "Рабочая память событий по сюжетным линиям. Не хранит анкеты персонажей: анкеты лежат в characters/main/*.md.",
  "rules": {
    "no_one_scene_files": true,
    "character_cards_are_source_for_personality": true,
    "this_file_stores_only_events_relationships_knowledge_obligations": true,
    "shared_event_written_once_then_referenced_by_lines": true,
    "every_event_requires_absolute_date": true,
    "relative_dates_must_be_calculated_from_current_state_date": true,
    "compact_every_turns": 15,
    "compaction_does_not_delete_important_memory": true
  },
  "turn_counter": {
    "total_game_turns": 0,
    "since_last_compaction": 0,
    "compact_every_turns": 15,
    "last_compaction_turn": 0,
    "last_compaction_date": null,
    "last_compaction_note": null,
    "technical_turns_do_not_count": true
  },
  "compaction_policy": {
    "game_turns_only": true,
    "technical_turns_do_not_count": true,
    "debug_audit_rule_edits_do_not_count": true,
    "preserve_open_threads": true,
    "preserve_obligations": true,
    "preserve_first_meetings": true,
    "preserve_knowledge_boundaries": true,
    "preserve_named_npc_identity": true,
    "preserve_unknown_name_descriptors": true,
    "preserve_relationship_causes": true,
    "preserve_reputation_causes": true,
    "compress_repeated_minor_events": true,
    "compress_completed_progress_logs": true,
    "do_not_erase_reason_for_current_reaction": true,
    "daily_timeline_is_not_deleted": true,
    "shared_events_can_be_reduced_to_refs_after_summary": true
  },
  "calendar_policy": {
    "date_format": "YYYY-MM-DD внутри данных, человекочитаемо в summary: 15 августа 1198",
    "relative_date_rules": {
      "same_day": "сегодня / утром / днём / вечером, если дата совпадает",
      "one_day_ago": "вчера",
      "two_days_ago": "позавчера / два дня назад",
      "three_to_six_days_ago": "несколько дней назад / N дней назад",
      "seven_days_ago": "неделю назад",
      "more_than_seven_days_ago": "называть точную дату или период"
    },
    "hard_rule": "Персонажи не должны говорить 'вчера' про событие, если между current_state.date и event.date прошло больше одного дня."
  },

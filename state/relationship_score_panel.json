{
  "schema_version": "relationship_score_panel_v2",
  "relationship_score_formula": {
    "positive_weights": {
      "affection": 1.2,
      "trust": 1.2,
      "respect": 1.0,
      "interest": 0.8,
      "curiosity": 0.8,
      "warmth": 1.2,
      "attachment": 1.5
    },
    "negative_weights": {
      "tension": -0.8,
      "irritation": -0.7,
      "fear": -1.0,
      "resentment": -1.2,
      "suspicion": -1.0,
      "jealousy": -0.4
    },
    "clamp": [-100, 100],
    "round": true,
    "note": "Visible panel shows total score, not per-scene delta. It may be recalculated from relationships.json. Interest/curiosity alone is not warmth."
  },
